<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    tools:context=".Activities.RegistrationActivity"
    android:padding="30dp"
    android:background="#fff">

    <ImageView
        android:id="@+id/imageViewLogo1"
        android:layout_width="75dp"
        android:layout_height="75dp"
        android:src="@drawable/golfmax_logos_black"/>

    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textViewAverageScore"
            android:layout_width="175dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:text="0.0"
            android:textAlignment="center"
            android:textSize="80dp"
            android:textColor="#013220"/>

        <TextView
            android:id="@+id/texViewHandicapIndex"
            android:layout_width="175dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:text="0.0"
            android:textAlignment="center"
            android:textSize="80dp"
            android:textColor="#013220"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="175dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:text="Average Score"
            android:textAlignment="center"
            android:textSize="20dp" />

        <TextView
            android:layout_width="175dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:text="Handicap Index"
            android:textAlignment="center"
            android:textSize="20dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="50dp">

        <Button
            android:id="@+id/buttonViewScores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#fff"
            android:text="View Scores"
            android:textColor="#013220" />

        <Button
            android:id="@+id/buttonPlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#fff"
            android:text="Play a round"
            android:textColor="#013220" />

        <Button
            android:id="@+id/buttonLeaderboards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#fff"
            android:text="Course Leaderboards"
            android:textColor="#013220" />

        <Button
            android:id="@+id/buttonSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#fff"
            android:text="settings"
            android:textColor="#013220" />

    </LinearLayout>

</LinearLayout>